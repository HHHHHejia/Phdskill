{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "experiment_matrix.yaml",
  "type": "object",
  "required": ["hypothesis", "datasets", "baselines", "metrics", "experiments", "approval"],
  "properties": {
    "hypothesis": {
      "type": "object",
      "properties": {
        "primary": {"type": "string"},
        "secondary": {"type": "array"}
      }
    },
    "datasets": {"type": "array"},
    "baselines": {"type": "array"},
    "metrics": {"type": "array"},
    "experiments": {"type": "array"},
    "approval": {
      "type": "object",
      "properties": {
        "required": {"type": "boolean"},
        "approved_by_user": {"type": "boolean"},
        "approved_at": {"type": ["string", "null"]}
      }
    }
  }
}
