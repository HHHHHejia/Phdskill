{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "finding_cards.yaml",
  "type": "object",
  "required": ["findings"],
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {"type": "string"},
          "statement": {"type": ["string", "null"]},
          "evidence": {
            "type": "object",
            "properties": {
              "experiments": {"type": "array"},
              "metrics": {"type": "array"},
              "logs": {"type": "array"}
            }
          },
          "strength": {"type": "string"},
          "supports_claim": {"type": ["string", "null"]},
          "limitations": {"type": ["string", "null"]},
          "can_use_in_abstract": {"type": "boolean"}
        }
      }
    }
  }
}
