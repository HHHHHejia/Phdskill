{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "paper_cards.yaml",
  "type": "object",
  "required": ["papers"],
  "properties": {
    "papers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": ["string", "null"]},
          "authors": {"type": "array"},
          "year": {"type": ["integer", "null"]},
          "venue": {"type": ["string", "null"]},
          "url": {"type": ["string", "null"]},
          "bibtex_key": {"type": ["string", "null"]},
          "problem": {"type": ["string", "null"]},
          "method": {"type": ["string", "null"]},
          "dataset": {"type": ["string", "null"]},
          "evaluation": {"type": ["string", "null"]},
          "main_claim": {"type": ["string", "null"]},
          "limitations": {"type": ["string", "null"]},
          "relevance_to_project": {"type": ["string", "null"]},
          "threat_to_novelty": {"type": ["string", "null"]},
          "useful_for": {"type": ["string", "null"]},
          "confidence": {"type": ["string", "number", "null"]}
        }
      }
    }
  }
}
